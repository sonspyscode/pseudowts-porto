---
import { Image } from 'astro:assets';

// ASET MODE 1: DESIGN PORTFOLIO (Menggunakan 2 Layer Gambar)
import bgLift from '../assets/images/bg-lift.jpg'; 
import fotoBadan from '../assets/images/bg-badan.png'; 

// ASET MODE 2: CODE & CYBER PORTFOLIO (HANYA 1 GAMBAR BACKGROUND UTAMA)
// Perbaikan: Import foto-badan-code dihapus karena tidak digunakan
import bgCode from '../assets/images/bg-code.jpg'; 
---

<section class="relative h-dvh w-full flex flex-col justify-between pt-28 pb-16 md:pb-24 px-6 md:px-16 overflow-hidden bg-black">
  
  <div id="wrapper-mode-design" class="absolute inset-0 z-0 transition-all duration-500 opacity-100 block">
    <div class="absolute inset-0 z-0">
      <Image src={bgLift} alt="Latar belakang lift" quality="100" format="webp" loading="eager" class="w-full h-full object-cover object-center pointer-events-none select-none" />
    </div>

    <div class="absolute inset-0 flex flex-col items-center justify-center text-center z-10 pointer-events-none transform translate-y-[-170px] md:-translate-y-34">
      <div class="relative flex flex-col items-center w-full justify-center select-none px-4">
        <h2 class="font-serif-italics text-[2.35rem] sm:text-4xl md:text-5xl lg:text-6xl text-gray-200 tracking-wide mb-1 md:mb-2 drop-shadow-md">
          I'm ui/ux
        </h2>
        <h1 class="font-brush text-[4.0rem] sm:text-7xl md:text-[8rem] lg:text-[10rem] uppercase tracking-wider text-white leading-none transform -rotate-1 drop-shadow-2xl opacity-95 flex items-center justify-center gap-2 sm:gap-16 md:gap-[14rem] mt-1 md:mt-14 md:translate-y-20">
          <span class="transform -translate-x-[15px] md:translate-x-15 transition-transform">DESI</span>
          <span class="transform translate-x-[32px] md:translate-x-0 transition-transform">GNER</span>
        </h1>
      </div>
    </div>

    <div class="absolute inset-0 z-20 pointer-events-none">
      <Image src={fotoBadan} alt="Foto Profil Depan Teks" quality="100" format="png" loading="eager" class="w-full h-full object-cover object-center pointer-events-none select-none" />
    </div>
  </div>


  <div id="wrapper-mode-code" class="absolute inset-0 z-0 transition-all duration-500 opacity-0">
    <div class="absolute inset-0 z-0">
      <Image src={bgCode} alt="Latar belakang code" quality="100" format="webp" class="w-full h-full object-cover object-center pointer-events-none select-none" />
    </div>

    <div class="absolute inset-0 flex flex-col items-start justify-center text-left z-10 pointer-events-none transform translate-y-[-20px] md:-translate-y-20 pl-6 md:pl-24 w-full max-w-7xl mx-auto">
      <div class="relative flex flex-col items-start w-full select-none gap-0 md:gap-2">
        
        <div class="font-code text-sm translate-y-5 lg:translate-y-10 sm:text-base md:text-xl text-green-400 tracking-mono opacity-90 flex items-center gap-2">
          <span class="animate-pulse text-[1.0rem] md:text-[1.5rem]">~$</span>
          <span class="animate-pulse text-[1.5rem] md:text-[2.0rem]">whoami</span>
        </div>
        
        <h2 class="font-code-b text-[2.2rem] sm:text-5xl md:text-[4.5rem] lg:text-[4.5rem] text-gray-200 tracking-tight drop-shadow-md capitalize leading-tight mt-4 md:mt-6">
          Digital forensic
        </h2>
        
        <h1 class="font-code-b -translate-y-3 lg:-translate-y-5 text-[2.8rem] sm:text-6xl md:text-[6rem] lg:text-[4.5rem] text-gray-200 tracking-tight drop-shadow-md capitalize leading-none mt-1">
          researcher
        </h1>
        
      </div>
    </div>
  </div>

  <div class="relative w-full max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-end sm:items-end z-30 mt-auto pt-5 gap-4 sm:gap-0 bg-black/40 sm:bg-transparent p-4 sm:p-0 rounded-xl backdrop-blur-sm sm:backdrop-blur-none">
    
    <div class="max-w-xs md:max-w-sm text-left w-full sm:w-auto">
      <p id="text-description" class="text-[11px] md:text-sm text-gray-400 font-light leading-normal tracking-wide m-0 transition-all duration-300">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
      </p>
    </div>
    
    <button class="bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-bold py-1 px-2 rounded-[6.0px] 
                  hover:from-cyan-600 hover:to-blue-600 transition shadow-lg
                      hover:shadow-xl hover: -translate-1 hover:scale-105 active:scale-95">
      <a href="#contact" class="w-full sm:w-auto text-center inline-block text-white font-medium text-xs md:text-sm px-6 py-2.5 rounded-md transition-all duration-300">
        Kenalan Yuk!
      </a>
    </button>

  </div>

</section>

<script>
  const btnCode = document.getElementById('btn-mode-code');
  const btnDesign = document.getElementById('btn-mode-design');
  const indicator = document.getElementById('squishy-indicator');
  
  // Ambil elemen pembungkus konten halaman Anda jika ada di page design
  const wrapperDesign = document.getElementById('wrapper-mode-design');
  const wrapperCode = document.getElementById('wrapper-mode-code');
  const textDesc = document.getElementById('text-description');

  if (btnCode && btnDesign && indicator) {
    const imgCode = btnCode.querySelector('img');
    const imgDesign = btnDesign.querySelector('img');

    // KUNCI UTAMA: Geser kotak biru langsung ke posisi Pentool saat halaman design dimuat
    indicator.style.transform = 'translateX(28px)';

    // ==================== JIKA USER KLIK CODE MODE (Kembali ke halaman utama/mode code) ====================
    btnCode.addEventListener('click', () => {
      // Jalankan efek squishy membal ke kiri
      indicator.style.transformOrigin = 'right center';
      indicator.style.transform = 'translateX(0px) scaleX(1.4)';
      setTimeout(() => {
        indicator.style.transform = 'translateX(0px) scaleX(1)';
      }, 180);

      if (imgCode) imgCode.classList.replace('opacity-40', 'opacity-100');
      if (imgDesign) imgDesign.classList.replace('opacity-100', 'opacity-40');

      // Jika tombol ini berada di halaman terpisah, Anda bisa mengarahkan user kembali ke Beranda mode Code:
      // window.location.href = "/?mode=code";
    });

    // ==================== JIKA USER KLIK DESIGN MODE ====================
    btnDesign.addEventListener('click', () => {
      // Jalankan efek squishy tetap di posisi kanan (Pentool)
      indicator.style.transformOrigin = 'left center';
      indicator.style.transform = 'translateX(28px) scaleX(1.4)';
      setTimeout(() => {
        indicator.style.transform = 'translateX(28px) scaleX(1)';
      }, 180);

      if (imgDesign) imgDesign.classList.replace('opacity-40', 'opacity-100');
      if (imgCode) imgCode.classList.replace('opacity-100', 'opacity-40');
    });
  }
</script>
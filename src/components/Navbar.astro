---
import { Image } from 'astro:assets';
import logoGambar from '../assets/images/logo.svg'; 
import iconCode from '../assets/images/icon-code.svg';
import pentoolNibIcon from '../assets/images/icon-pen.svg'; 
---

<header class="absolute top-0 left-0 w-full z-50 px-6 py-6 md:px-16 flex justify-between items-center bg-gradient-to-b from-black/50 to-transparent">
  
  <div class="flex-1 flex justify-start">
    <a href="/" class="flex items-center h-6 sm:h-7 md:h-8 w-auto transition-opacity hover:opacity-80">
      <Image src={logoGambar} alt="Logo" loading="eager" class="h-full w-auto object-contain" />
    </a>
  </div>

  <div class="flex-none flex items-center justify-center">
    <div class="flex items-center bg-zinc-900/80 backdrop-blur-md rounded-lg p-1 border border-zinc-800 shadow-inner">
      
      <button id="btn-mode-code" class="p-1.5 rounded w-7 h-7 flex items-center justify-center cursor-pointer group transition-all duration-300" aria-label="Switch to Code Mode">
        <Image 
          src={iconCode} 
          alt="Code Mode" 
          class="w-4 h-4 object-contain opacity-40 group-hover:opacity-90 transition-all duration-300" 
        />
      </button>
      
      <button id="btn-mode-design" class="p-1.5 rounded bg-blue-600 shadow-md w-7 h-7 flex items-center justify-center cursor-pointer transition-all duration-300" aria-label="Design Mode (Active)">
        <Image 
          src={pentoolNibIcon} 
          alt="Design Mode (Active)" 
          class="w-4 h-4 object-contain opacity-100" 
        />
      </button>
    </div>
  </div>

  <div class="flex-1 flex justify-end">
    <button class="flex flex-col gap-1.5 justify-center items-center w-8 h-8 group" aria-label="Menu">
      <span class="w-6 h-0.5 bg-white transition-all group-hover:w-5"></span>
      <span class="w-6 h-0.5 bg-white transition-all"></span>
      <span class="w-6 h-0.5 bg-white transition-all group-hover:w-4"></span>
    </button>
  </div>

</header>